<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forçar HTTPS (Descomente as duas linhas abaixo se desejar forçar o SSL/HTTPS sempre)
  # RewriteCond %{HTTPS} off
  # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Impedir listagem de diretórios (proteção)
  Options -Indexes

  # Regra para o React (Redireciona qualquer URL que não seja arquivo/pasta real para o index.html)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
